# Nixpacks PHP Configuration
NIXPACKS_PHP_ROOT_DIR=/app/public
NIXPACKS_PHP_FALLBACK_PATH=/index.php

# Laravel Application
APP_NAME="Your Real Estate Site Name" # Change this to your actual site name
APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_URL=https://your-actual-domain.com

# Database Configuration (MySQL from Coolify)
DB_CONNECTION=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_DATABASE=homzen
# DB_USERNAME=
# DB_PASSWORD=

# Botble Configuration
ADMIN_DIR=admin
CMS_ENABLE_INSTALLER=false

# Laravel Basics
LOG_CHANNEL=daily
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync

