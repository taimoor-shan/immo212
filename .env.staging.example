# Staging Environment Configuration for IMMO212 Real Estate Platform
# Copy this file to .env on your staging server and customize the values

# Application Configuration
APP_NAME="IMMO212 Real Estate (Staging)"
APP_ENV=staging
APP_KEY=base64:YOUR_STAGING_APP_KEY_HERE
APP_DEBUG=true
APP_URL=https://staging.yourdomain.com

# Database Configuration (CloudPanel MySQL)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_staging_database
DB_USERNAME=your_staging_db_user
DB_PASSWORD=your_staging_db_password

# Botble CMS Configuration
ADMIN_DIR=admin
CMS_ENABLE_INSTALLER=false

# Cache Configuration
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync

# Mail Configuration (Use Mailtrap or similar for testing)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=staging@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"

# Logging (More verbose for staging)
LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Performance & Security (Relaxed for staging)
BCRYPT_ROUNDS=10
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# File Storage
FILESYSTEM_DISK=local

# Social Login (Use test credentials)
FACEBOOK_CLIENT_ID=test_facebook_id
FACEBOOK_CLIENT_SECRET=test_facebook_secret
FACEBOOK_REDIRECT_URI=https://staging.yourdomain.com/auth/facebook/callback

GOOGLE_CLIENT_ID=test_google_id
GOOGLE_CLIENT_SECRET=test_google_secret
GOOGLE_REDIRECT_URI=https://staging.yourdomain.com/auth/google/callback

# Payment Gateways (Use sandbox/test mode)
STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key
STRIPE_SECRET_KEY=sk_test_your_test_key
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret

PAYPAL_CLIENT_ID=test_paypal_client_id
PAYPAL_CLIENT_SECRET=test_paypal_client_secret
PAYPAL_MODE=sandbox

# Analytics (Disabled for staging)
GOOGLE_ANALYTICS_ID=
GOOGLE_TAG_MANAGER_ID=

# Real Estate Plugin Configuration
REAL_ESTATE_ENABLE_CREDITS_SYSTEM=true
REAL_ESTATE_ENABLE_REVIEW_FEATURE=true
REAL_ESTATE_ENABLE_WISHLIST=true

# Performance Optimization (Disabled for easier debugging)
OPTIMIZE_CLEAR_CACHE=false
OPTIMIZE_CONFIG_CACHE=false
OPTIMIZE_ROUTE_CACHE=false
OPTIMIZE_VIEW_CACHE=false

# Security Headers
SECURE_HEADERS_ENABLED=false

# Staging-specific settings
STAGING_PASSWORD=your_staging_password
STAGING_ENABLED=true
