# Dependencies (will be installed during deployment)
/node_modules
/vendor

# Build artifacts (will be built during deployment)
/public/hot
/public/build
/public/themes/*/css/
/public/themes/*/js/
/public/vendor/
/public/storage
/public/mix-manifest.json
*.css.map
*.js.map

# Environment files
/.env
.env.example
.env.production

# Cache and temporary files (generated at runtime)
/storage/*.key
/storage/logs/*.log
/storage/debugbar/*.json
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/testing/*
/storage/framework/views/*
/bootstrap/cache/*.php

# Development and testing
/.phpunit.cache
.phpunit.result.cache
/reference-code

# IDE and editor files
/.fleet
/.idea
/.vscode

# Package manager logs
npm-debug.log
yarn-error.log

# Deployment files
Homestead.json
Homestead.yaml
auth.json

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~

# Note: Keep package-lock.json for consistent dependency versions
# Note: Keep /public/storage and user uploads - no external storage in Coolify
